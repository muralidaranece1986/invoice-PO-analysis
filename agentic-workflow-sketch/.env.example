# Invoice-PO Matching Service Configuration
# Copy to .env and fill in required values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO

# Model Configuration
MODEL_PATH=src/matcher/model_artifacts.pkl
ML_THRESHOLD=0.50

# Matching Thresholds
DATE_WINDOW_DAYS=180
AMOUNT_TOLERANCE_PCT=0.15
VENDOR_MATCH_REQUIRED=true

# LLM Configuration (for email drafting)
# Options: openai, anthropic, mock
LLM_PROVIDER=mock
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Data Paths
DATA_PATH=data/
INVOICES_CSV=data/invoices.csv
POS_CSV=data/po_grn.csv
MISMATCHES_CSV=data/labelled_mismatches.csv

# Database (for production persistence)
# DATABASE_URL=postgresql://user:password@localhost/invoice_po
DATABASE_ENABLED=false

# Monitoring & Logging
SENTRY_DSN=https://...
PROMETHEUS_METRICS_PORT=9090

# Audit & Compliance
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years
ENCRYPT_AT_REST=false
